call DisableTrigger(GetTriggeringTrigger())
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
else
call AdjustPlayerStateBJ(150,GetOwningPlayer(GetKillingUnitBJ()),PLAYER_STATE_RESOURCE_GOLD)
call DisplayTimedTextToForce(GetPlayersAll(),10.00,(Il11[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]+" первый убил 50 врагов! и он получает |cffffff00100 ед золота."))
