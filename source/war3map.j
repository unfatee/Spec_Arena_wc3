function CodexKalekaRotRunForHero takes unit u returns nothing
local integer level=GetUnitAbilityLevelSwapped(0x4130424C,u)
local real base=0.
local real mult=0.10
local location p=null
if(level<=0)then
return
endif
if(UnitHasBuffBJ(u,0x42303136)==false and UnitHasBuffBJ(u,0x42456961)==false)then
return
endif
if(level==1)then
set base=15.
elseif(level==2)then
set base=30.
elseif(level==3)then
set base=45.
elseif(level==4)then
set base=60.
elseif(level==5)then
set base=75.
elseif(level==6)then
set base=90.
elseif(level==7)then
set base=105.
set mult=0.50
else
set base=120.
endif
set CodexKalekaRotCaster=u
set CodexKalekaRotDamage=base*mult*I2R(GetHeroStatBJ(bj_HEROSTAT_STR,u,true))
set p=GetUnitLoc(u)
set bj_wantDestroyGroup=true
call ForGroupBJ(Il1lI1I(200.00,p,Condition(function CodexKalekaRotFilter)),function CodexKalekaRotDamageEnum)
call RemoveLocation(p)
set p=null
endfunction
