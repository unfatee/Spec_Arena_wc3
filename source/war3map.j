call DisplayTimedTextToForce(GetPlayersAll(),10.00,(Il11[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]+" первый убил 50 врагов! |cffffff00100 ед золота разделенно между игроками."))
